                    </div>
                </div>

                <!-- RIGHT: Shipping To -->
                <div class="col-md-6">
                    <div class="card border-secondary h-100">

                        <div class="card-header fw-bold text-center py-1 small">
                            Shipping To
                        </div>

                        <div class="card-body py-2 px-2">

                            <!-- Select Company -->
                            <div class="row mb-1">
                                <label class="col-sm-4 col-form-label py-1 small fw-bold">
                                    Select Company :
                                </label>
                                <div class="col-sm-8">
                                    <select id="shippingTo" class="form-select form-select-sm"
                                            onchange="loadCompanyDetails('shippingTo')">
                                        @foreach (var c in Model.Companies)
                                        {
                                            <option>@c.Text</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <!-- Details -->
                            <table class="table table-sm table-borderless mb-0">
                                <tr>
                                    <td colspan="2" class="fw-bold text-center small" id="st_CompanyName"></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold" style="width:35%">Address :</td>
                                    <td id="st_Address"></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">State Code :</td>
                                    <td id="st_StateCode"></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">State :</td>
                                    <td id="st_State"></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">GSTIN :</td>
                                    <td id="st_GSTIN" class="fw-bold"></td>
                                </tr>
                            </table>

                        </div>
                    </div>
                </div>

            </div>
            <!-- ===================== ITEMS TABLE ===================== --> 
           
            <div class="card border-secondary mb-2">

                <div class="card-header fw-bold py-1 small">
                    Items
                </div>

                <div class="card-body p-0">

                    <table class="table table-bordered table-sm mb-0 align-middle" id="itemsTable">

                        <thead class="table-light small">
                            <tr>
                                <th class="text-center py-1" style="width:5%">Sr</th>
                                <th class="py-1" style="width:35%">Item Description</th>
                                <th class="text-center py-1" style="width:15%">HSN</th>
                                <th class="text-center py-1" style="width:13%">Rate</th>
                                <th class="text-center py-1" style="width:10%">Qty</th>
                                <th class="text-center py-1" style="width:14%">Amount</th>
                                <th class="text-center py-1" style="width:5%"></th>
                            </tr>
                        </thead>

                        <tbody id="itemsBody" class="small">
                            <tr>
                                <td class="text-center">1</td>

                                <td>
                                    <select class="form-select form-select-sm item-select"
                                            onchange="onItemChange(this)">
                                        <option value="">-- Select --</option>
                                        @foreach (var i in Model.ItemsList)
                                        {
                                            <option>@i.Text</option>
                                        }
                                    </select>
                                </td>

                                <td class="hsn text-center"></td>

                                <td class="rate text-center"></td>

                                <td>
                                    <input type="number"
                                           class="form-control form-control-sm qty text-center"
                                           oninput="calcRow(this)" min="0" step="any" />
                                </td>

                                <td class="amount text-center">0.00</td>

                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-danger py-0 px-2"
