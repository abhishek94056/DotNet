@using InvoiceGenerator
@using InvoiceGenerator.Models
@using InvoiceGenerator.ViewModels
@using InvoiceGenerator.Services
@using Microsoft.AspNetCore.Mvc.Rendering
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model InvoiceViewModel
@{
    ViewData["Title"] = "Create Invoice";
}

<!-- Hidden options template (Razor renders once on server, JS clones for new rows) -->
<select id="itemOptionsTemplate" style="display:none">
    <option value="">-- Select --</option>
    @foreach (var i in Model.ItemsList)
    {
        <option>@i.Text</option>
    }
</select>

<div class="container-fluid mt-0">
    <div class="card shadow-sm">

        <!-- ===== HEADER ===== -->
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">🧾 TAX INVOICE</h5>
            @* <strong id="invoiceLabel">@Model.NextInvoiceLabel</strong> *@
        </div>

        <div class="card-body py-1">

            <!-- ===================== ROW 1: Company Info + PO/DC Details ===================== -->
          
