                            <div class="row mb-1">
                                <label class="col-sm-4 col-form-label py-1 small fw-bold">ASN No. :</label>
                                <div class="col-sm-8">
                                    <input type="text" id="ASNNo" class="form-control form-control-sm" />
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

            </div>
            <!-- ===================== ROW 2: Invoice To + Shipping To ===================== -->
           
