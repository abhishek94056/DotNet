                        </tbody>

                    </table>
                </div>

                <div class="card-footer py-1 px-2">
                    <button class="btn btn-secondary btn-sm py-0 px-2"
                            onclick="addRow()">
                        + Row
                    </button>
                </div>

            </div>
         
            <!-- ===================== BANK DETAILS + TOTALS ===================== -->
