                    <div class="small">
                        <div><b>BANK :</b> IDBI BANK</div>
                        <div><b>A/C NAME :</b> CODNOW TECHNOLOGIES</div>
                        <div><b>A/C NO :</b> 0076102000048736</div>
                        <div><b>IFSC :</b> IBKL0000076</div>
                    </div>
                </div>

                <!-- RIGHT: Totals -->
                <div class="col-md-4">
                    <table class="table table-sm table-bordered mb-0 small">
                        <tr>
                            <td class="py-1">Taxable Value</td>
                            <td class="text-end fw-bold py-1" id="taxableValue">0.00</td>
                        </tr>
                        <tr>
                            <td class="py-1">CGST 9%</td>
                            <td class="text-end py-1" id="cgst">0.00</td>
                        </tr>
                        <tr>
                            <td class="py-1">SGST 9%</td>
                            <td class="text-end py-1" id="sgst">0.00</td>
                        </tr>
                        <tr>
                            <td class="py-1">IGST 18%</td>
                            <td class="text-end py-1" id="igst">0.00</td>
                        </tr>
                        <tr class="table-primary fw-bold">
                            <td class="py-1">Total Value</td>
                            <td class="text-end py-1" id="totalValue">0.00</td>
                        </tr>
                    </table>
                </div>
            </div>

            <!-- ===================== DECLARATION ===================== -->
            <div class="mb-2 small">

                <!-- In Words -->
                <div class="mb-1">
                    <span class="fw-bold">In Words :</span>
                    <span id="totalWords"></span>
                </div>

                <!-- Transport Mode -->
                <div class="mb-1 d-flex align-items-center gap-1">
                    <span class="fw-bold">Transport Mode :</span>
                    <select id="transportMode" class="form-select form-select-sm w-auto"
                            onchange="recalcTotal()">
                        @foreach (var m in Model.TransportModes)
                        {
                            <option>@m.Text</option>
                        }
                    </select>
                </div>

                <!-- Transporter -->
                <div class="mb-1">
                    <span class="fw-bold">Transporter :</span>
                    <span>CodNow Technologies</span>
                </div>

                <!-- Remark -->
                <div class="mb-1 d-flex align-items-center gap-1 ">
                    <span class="fw-bold">Remark :</span>
