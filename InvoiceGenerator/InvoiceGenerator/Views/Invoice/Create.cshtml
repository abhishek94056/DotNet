                                        Deolai Road, Chhatrapati Sambhajinagar - 431001
                                    </p>
                                </div>
                            </div>

                            <div class="row mb-1">
                                <label class="col-sm-4 col-form-label fw-bold">Phone :</label>
                                <div class="col-sm-8">
                                    <p class="form-control-plaintext">+91 9923 8888 91 / +91 7972 3815 80</p>
                                </div>
                            </div>

                            <div class="row mb-1">
                                <label class="col-sm-4 col-form-label fw-bold">State Code :</label>
                                <div class="col-sm-8">
                                    <p class="form-control-plaintext">27 &nbsp;&nbsp; <strong>State :</strong> Maharashtra</p>
                                </div>
                            </div>

                            <div class="row mb-1">
                                <label class="col-sm-4 col-form-label fw-bold">GSTIN :</label>
                                <div class="col-sm-8">
                                    <p class="form-control-plaintext fw-bold">27FAEPS7663Q1ZK</p>
                                </div>
                            </div>

                            <div class="row mb-1">
                                <label class="col-sm-4 col-form-label fw-bold">PAN :</label>
                                <div class="col-sm-8">
                                    <p class="form-control-plaintext">FAEPS7663Q</p>
                                </div>
                            </div>


                        </div>
                    </div>
                </div>

                <!-- RIGHT: Invoice / PO / DC Details -->
                <div class="col-md-6">
                    <div class="card border-secondary h-100">

                        <div class="card-header fw-bold text-center py-1 small">
                            Invoice / PO / DC Details
                        </div>

                        <div class="card-body py-1 px-2">

                            <div class="row mb-1">
                                <label class="col-sm-4 col-form-label py-1 small fw-bold">Invoice No :</label>
