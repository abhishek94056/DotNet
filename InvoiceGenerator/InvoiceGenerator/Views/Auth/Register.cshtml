@model InvoiceGenerator.ViewModels.RegisterViewModel
@{ ViewData["Title"] = "Register"; Layout = null; }

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register — Invoice Generator</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
        body { background: #f0f2f5; }
        .reg-card {
            max-width: 460px;
            margin: 10px auto;
            border-radius: 12px;
            box-shadow: 0 4px 24px rgba(0,0,0,.10);
        }
        .reg-header {
            background: #212529;
            color: #fff;
            border-radius: 12px 12px 0 0;
            padding: 2px;
            text-align: center;
        }
    </style>
</head>
<body>

<div class="reg-card card border-0">

    <div class="reg-header">
        <img src="~/images/Logo.png" alt="Logo" height="40" />
        <h6 class="mb-0 mt-1">Create Account</h6>
    </div>

    <div class="card-body p-2">

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger py-2 small"></div>

            <div class="mb-3">
                <label asp-for="Name"
                       class="form-label fw-semibold small">Full Name</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-person"></i>
                    </span>
                    <input asp-for="Name" class="form-control"
                           placeholder="Abhishek More" />
                </div>
                <span asp-validation-for="Name"
                      class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email"
                       class="form-label fw-semibold small">Email</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-envelope"></i>
                    </span>
                    <input asp-for="Email" class="form-control"
                           placeholder="you@example.com" />
                </div>
                <span asp-validation-for="Email"
                      class="text-danger small"></span>
            </div>
            @* ========================= *@
            @* <div class="mb-3">
                <label asp-for="Role"
                       class="form-label fw-semibold small">Role</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-person-badge"></i>
                    </span>
                    <input asp-for="Role" class="form-control"
                           placeholder="Admin" />
                </div>
                <span asp-validation-for="Role"
                      class="text-danger small"></span>
            </div> *@

            <div class="mb-3">
    <label asp-for="Role"
           class="form-label fw-semibold small">Role</label>

    <div class="input-group">
        <span class="input-group-text">
            <i class="bi bi-person-badge"></i>
        </span>

        <select asp-for="Role" class="form-select">
            <option value="">-- Select Role --</option>
            <option value="Admin">Admin</option>
            <option value="User">User</option>
        </select>
    </div>

    <span asp-validation-for="Role"
          class="text-danger small"></span>
</div>

            <div class="mb-3">
                <label asp-for="Password"
                       class="form-label fw-semibold small">Password</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-lock"></i>
                    </span>
                    <input asp-for="Password" type="password"
                           class="form-control"
                           placeholder="Min 6 characters"
                           id="pwd1" />
                    <button type="button"
                            class="btn btn-outline-secondary"
                            onclick="togglePwd('pwd1','eye1')">
                        <i class="bi bi-eye" id="eye1"></i>
                    </button>
                </div>
                <span asp-validation-for="Password"
                      class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword"
                       class="form-label fw-semibold small">Confirm Password</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-lock-fill"></i>
                    </span>
                    <input asp-for="ConfirmPassword" type="password"
                           class="form-control"
                           placeholder="Re-enter password"
                           id="pwd2" />
                    <button type="button"
                            class="btn btn-outline-secondary"
                            onclick="togglePwd('pwd2','eye2')">
                        <i class="bi bi-eye" id="eye2"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword"
                      class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-dark w-100">
                <i class="bi bi-person-plus me-1"></i>Register
            </button>
        </form>

        <hr class="my-3" />

        <div class="text-center small">
            Already have an account?
            <a asp-action="Login" class="fw-bold">Login</a>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function togglePwd(inputId, iconId) {
        const inp  = document.getElementById(inputId);
        const icon = document.getElementById(iconId);
        inp.type   = inp.type === 'password' ? 'text' : 'password';
        icon.className = inp.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
    }
</script>
</body>
</html>