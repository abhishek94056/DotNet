    </button>
</div>

<!-- ── GRID ── -->
<div class="table-responsive">
    <table class="table table-bordered table-hover table-sm align-middle" id="companyTable">
        <thead class="table-dark text-center">
            <tr>
                <th>#</th>
                <th>Company Name</th>
                <th>Address</th>
                <th>State Code</th>
                <th>State</th>
                <th>GSTIN</th>
                <th>Payment Term</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
