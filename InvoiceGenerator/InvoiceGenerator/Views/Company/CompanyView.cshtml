<!-- ── ADD / EDIT MODAL ── -->
<div class="modal fade" id="companyModal" tabindex="-1"
     aria-labelledby="modalTitle" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h6 class="modal-title" id="modalTitle">
                    <i class="bi bi-building me-2"></i>
                    <span id="modalTitleText">Add Company</span>
                </h6>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <form id="companyForm" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="companyId" name="CompanyId" value="0" />

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                Company Name <span class="text-danger">*</span>
                            </label>
                            <input type="text" id="companyName" name="CompanyName"
                                   class="form-control" maxlength="100"
                                   placeholder="e.g. ABC Pvt Ltd" />
                            <div class="invalid-feedback" id="err-companyName"></div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
