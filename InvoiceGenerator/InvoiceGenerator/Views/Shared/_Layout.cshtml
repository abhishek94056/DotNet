<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Invoice Generator</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/invoice.css" />
</head>
<body>

    <!-- ── TOP NAVBAR: Logo + Company Name + Hamburger ── -->
    <nav class="navbar navbar-light bg-white px-2 py-1 shadow-sm">
        <div class="d-flex align-items-center w-100 position-relative">

            <!-- Left: Logo -->
            <img src="~/images/Logo.png" alt="Logo" height="40" class="me-2" />

            <!-- Center: Company Name -->
            <div class="position-absolute top-50 start-50 translate-middle">
                <img src="~/images/Company Name.png" alt="Company Name" height="35" />
            </div>

            <!-- Right: Hamburger -->
            <button class="navbar-toggler ms-auto" type="button"
                    data-bs-toggle="offcanvas"
                    data-bs-target="#offcanvasNav"
                    aria-controls="offcanvasNav"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

        </div>
    </nav>

    <!-- ── OFFCANVAS MENU ── -->
    <div class="offcanvas offcanvas-end text-bg-dark"
         tabindex="-1"
         id="offcanvasNav"
         aria-labelledby="offcanvasNavLabel">

        <div class="offcanvas-header border-bottom border-secondary">
            <h5 class="offcanvas-title" id="offcanvasNavLabel">
                <i class="bi bi-grid-fill me-2"></i>Menu
            </h5>
            <button type="button"
                    class="btn-close btn-close-white"
                    data-bs-dismiss="offcanvas"
                    aria-label="Close"></button>
        </div>

        <div class="offcanvas-body px-0">
            <ul class="navbar-nav flex-column">

                <li class="nav-item">
                    <a class="nav-link px-3 py-2 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoice" ? "active" : "")"
                           href="@Url.Action("InvoiceView", "Invoice")">
                        <i class="bi bi-house-door me-2"></i>Home
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link px-3 py-2 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Company" ? "active" : "")"
                           href="@Url.Action("CompanyView", "Company")">
                        <i class="bi bi-building me-2"></i>Company Master
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link px-3 py-2 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Item" ? "active" : "")"
                           href="@Url.Action("ItemView", "Item")">
                        <i class="bi bi-box-seam me-2"></i>Item Master
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link px-3 py-2 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Transport" ? "active" : "")"
                           href="@Url.Action("TransportView", "Transport")">
                        <i class="bi bi-truck me-2"></i>Transport Master
                    </a>
                </li>

            </ul>
        </div>

    </div>
    <!-- ── END OFFCANVAS ── -->
    <!-- ── PAGE CONTENT ── -->
    <div class="container-fluid py-3 px-4 mt-2">
        @Html.AntiForgeryToken()
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>