@model List<InvoiceGenerator.Models.ItemModel>
@{
    ViewData["Title"] = "Item Master";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h5 class="mb-0 fw-bold">
        <i class="bi bi-box-seam me-2 text-primary"></i>Item Master
    </h5>
    <button class="btn btn-primary btn-sm" onclick="openModal()">
        <i class="bi bi-plus-lg me-1"></i>Add Item
    </button>
</div>

<!-- GRID -->
<div class="table-responsive">
    <table class="table table-bordered table-hover table-sm align-middle">
        <thead class="table-dark text-center">
            <tr>
                <th style="width:60px">#</th>
                <th>Item Code</th>
                <th>Item Description</th>
                <th style="width:140px">HSN Code</th>
                <th style="width:120px">Rate (₹)</th>
                <th style="width:100px">GST (%)</th>
                <th style="width:100px">Actions</th>
            </tr>
        </thead>
        <tbody id="itemTableBody">
            @foreach (var item in Model)
            {
                <tr id="row-@item.ItemId">
                    <td class="text-center">@item.ItemId</td>
                    <td>@item.ItemCode</td>
                    <td>@item.ItemDescription</td>
                    <td class="text-center">@item.HSNCode</td>
                    <td class="text-end pe-3">@item.Rate.ToString("0.00")</td>
                    <td class="text-center">@item.GST</td>
                    <td class="text-center">
                        <button class="btn btn-outline-primary btn-sm"
                                onclick="editItem(@item.ItemId)">
                            <i class="bi bi-pencil-square"></i>
                        </button>
                        <button class="btn btn-outline-danger btn-sm"
                                onclick="deleteItem(@item.ItemId, '@item.ItemDescription')">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- MODAL -->
<div class="modal fade" id="itemModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h6 class="modal-title">
                    <span id="modalTitleText">Add Item</span>
                </h6>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="itemForm" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="itemId" name="ItemId" value="0" />

                    <!-- Item Code -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Item Code *</label>
                        <input type="text" id="itemCode" name="ItemCode"
                               class="form-control" maxlength="20" />
                        <div class="invalid-feedback" id="err-itemCode"></div>
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Item Description *</label>
                        <input type="text" id="itemDescription" name="ItemDescription"
                               class="form-control" maxlength="100" />
                        <div class="invalid-feedback" id="err-itemDescription"></div>
                    </div>

                    <!-- HSN -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">HSN Code *</label>
                        <input type="text" id="hsnCode" name="HSNCode"
                               class="form-control" maxlength="50" />
                        <div class="invalid-feedback" id="err-hsnCode"></div>
                    </div>

                    <!-- Rate -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Rate *</label>
                        <input type="number" id="rate" name="Rate"
                               class="form-control" step="0.01" />
                        <div class="invalid-feedback d-block" id="err-rate"></div>
                    </div>

                    <!-- GST -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">GST (%) *</label>
                        <input type="number" id="gst" name="GST"
                               class="form-control" step="0.01" />
                        <div class="invalid-feedback" id="err-gst"></div>
                    </div>

                </form>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary btn-sm" onclick="saveItem()">Save</button>
            </div>

        </div>
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteModal">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-body text-center">
                Delete <strong id="deleteItemDescription"></strong> ?
            </div>
            <div class="modal-footer justify-content-center">
                <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-danger btn-sm" id="btnConfirmDelete">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const modal = new bootstrap.Modal(document.getElementById('itemModal'));
        const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
        let pendingDeleteId = null;

        // OPEN
        function openModal() {
            clearForm();
            modal.show();
        }

        // EDIT
        async function editItem(id) {
            const r = await fetch(`/Item/GetById?id=${id}`);
            const d = await r.json();

            document.getElementById('itemId').value = d.itemId;
            document.getElementById('itemCode').value = d.itemCode;
            document.getElementById('itemDescription').value = d.itemDescription;
            document.getElementById('hsnCode').value = d.hsnCode;
            document.getElementById('rate').value = d.rate;
            document.getElementById('gst').value = d.gst;

            modal.show();
        }

        // SAVE
        async function saveItem() {
            clearErrors();

            let valid = true;

            const itemCode = document.getElementById('itemCode').value.trim();
            const itemDescription = document.getElementById('itemDescription').value.trim();
            const hsnCode = document.getElementById('hsnCode').value.trim();
            const rate = parseFloat(document.getElementById('rate').value);
            const gst = parseFloat(document.getElementById('gst').value);

            if (!itemCode) { showError('itemCode','err-itemCode','Required'); valid=false; }
            if (!itemDescription) { showError('itemDescription','err-itemDescription','Required'); valid=false; }
            if (!hsnCode) { showError('hsnCode','err-hsnCode','Required'); valid=false; }
            if (!rate || rate<=0) { showError('rate','err-rate','Invalid'); valid=false; }
            if (!gst || gst<=0) { showError('gst','err-gst','Invalid'); valid=false; }

            if (!valid) return;

            const token = document.querySelector('[name="__RequestVerificationToken"]').value;

            const payload = new URLSearchParams({
                ItemId: document.getElementById('itemId').value,
                ItemCode: itemCode,
                ItemDescription: itemDescription,
                HSNCode: hsnCode,
                Rate: rate,
                GST: gst,
                __RequestVerificationToken: token
            });

            const r = await fetch('/Item/Save',{method:'POST',body:payload});
            const d = await r.json();

            if(d.success){
                location.reload();
            }
        }

        // DELETE
        function deleteItem(id,name){
            pendingDeleteId=id;
            document.getElementById('deleteItemDescription').textContent=name;
            deleteModal.show();
        }

        document.getElementById('btnConfirmDelete').onclick = async ()=>{
            const token = document.querySelector('[name="__RequestVerificationToken"]').value;

            await fetch('/Item/Delete',{
                method:'POST',
                body:new URLSearchParams({id:pendingDeleteId,__RequestVerificationToken:token})
            });

            location.reload();
        }

        // HELPERS
        function clearForm(){
            document.getElementById('itemId').value=0;
            document.getElementById('itemCode').value='';
            document.getElementById('itemDescription').value='';
            document.getElementById('hsnCode').value='';
            document.getElementById('rate').value='';
            document.getElementById('gst').value='';
        }

        function clearErrors(){
            document.querySelectorAll('.invalid-feedback').forEach(e=>e.textContent='');
            document.querySelectorAll('.form-control').forEach(e=>e.classList.remove('is-invalid'));
        }

        function showError(f,e,m){
            document.getElementById(f).classList.add('is-invalid');
            document.getElementById(e).textContent=m;
        }
    </script>
}