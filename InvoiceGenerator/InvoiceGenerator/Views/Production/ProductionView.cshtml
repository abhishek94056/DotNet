@{
    ViewData["Title"] = "Production & Inventory Master";
}

<style>
    #prodTable {
        font-size: 0.70rem;
    }
    #prodTable thead tr:first-child th {
        font-size: 0.68rem;
        padding: 4px 5px;
        white-space: nowrap;
        text-align: center;
        vertical-align: middle;
        background-color: #1a1a2e;
        color: #fff;
    }
    #prodTable thead tr:last-child th {
        font-size: 0.65rem;
        padding: 3px 4px;
        white-space: nowrap;
        text-align: center;
        background-color: #16213e;
        color: #e0e0e0;
    }
    #prodTable tbody td {
        padding: 3px 5px;
        vertical-align: middle;
        white-space: nowrap;
    }

    /* Alternating rows */
    #prodTable tbody tr:nth-child(odd)  { background-color: #f8f9fa; }
    #prodTable tbody tr:nth-child(even) { background-color: #eef2ff; }

    /* Hover */
    #prodTable tbody tr:hover {
        background-color: #cfe2ff !important;
        cursor: pointer;
        transition: background-color 0.15s ease;
    }

    /* Column group colors */
    .col-identity  { background-color: #e8f4fd !important; }
    .col-weight    { background-color: #fef9e7 !important; }
    .col-qty       { background-color: #eafaf1 !important; }
    .col-alert     { background-color: #fdf2f8 !important; }
    .col-fg        { background-color: #fef5e4 !important; }
    .col-cost      { background-color: #f0f4ff !important; }

    /* Row hover overrides column color */
    #prodTable tbody tr:hover td { background-color: #cfe2ff !important; }

    /* Status badges */
    .badge-ok      { background-color: #198754; color:#fff; }
    .badge-low     { background-color: #dc3545; color:#fff; }
    .badge-warn    { background-color: #ffc107; color:#000; }
    .badge-high    { background-color: #0d6efd; color:#fff; }

    /* Numeric cells right-align */
    .num { text-align: right; padding-right: 8px !important; }

    /* Sticky first 3 columns */
    #prodTable thead th:nth-child(1),
    #prodTable thead th:nth-child(2),
    #prodTable thead th:nth-child(3),
    #prodTable tbody td:nth-child(1),
    #prodTable tbody td:nth-child(2),
    #prodTable tbody td:nth-child(3) {
        position: sticky;
        left: 0;
        z-index: 2;
        background-color: inherit;
    }
    #prodTable thead th:nth-child(2),
    #prodTable tbody td:nth-child(2) { left: 38px; }
    #prodTable thead th:nth-child(3),
    #prodTable tbody td:nth-child(3) { left: 110px; }

    /* Pagination */
    .pagination-bar {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 5px;
        margin-top: 8px;
        font-size: 0.75rem;
    }
    .pagination-bar button {
        min-width: 28px;
        height: 26px;
        font-size: 0.70rem;
        padding: 0 5px;
        border-radius: 4px;
    }
    .pagination-bar button.active-page {
        background-color: #0d6efd;
        color: #fff;
        border-color: #0d6efd;
    }

    /* Summary cards */
    .summary-card {
        border-radius: 8px;
        padding: 8px 12px;
        font-size: 0.72rem;
    }
    .summary-card .val {
        font-size: 1.1rem;
        font-weight: 700;
    }
</style>

<!-- ══════════ PAGE HEADER ══════════ -->
<div class="d-flex align-items-center justify-content-between mb-2">
    <h6 class="mb-0 fw-bold">
        <i class="bi bi-kanban me-2 text-primary"></i>
        Production &amp; Inventory Master
        <span class="badge bg-secondary ms-1" style="font-size:0.65rem">CodNow</span>
    </h6>
    <div class="d-flex align-items-center gap-2">
        <!-- Department filter -->
        <select id="deptFilter" class="form-select form-select-sm"
                style="width:150px" onchange="filterTable()">
            <option value="">All Departments</option>
            <option>Hardware</option>
            <option>Software</option>
            <option>Networking</option>
            <option>Assembly</option>
            <option>QA / Testing</option>
        </select>
        <!-- Search -->
        <input type="text" id="searchInput"
               class="form-control form-control-sm"
               placeholder="🔍 Search..."
               style="width:160px"
               oninput="filterTable()" />
        <!-- Export hint -->
        <button class="btn btn-outline-success btn-sm"
                onclick="exportCSV()" title="Export to CSV">
            <i class="bi bi-download me-1"></i>CSV
        </button>
    </div>
</div>

<!-- ══════════ SUMMARY CARDS ══════════ -->
<div class="row g-2 mb-2" id="summaryCards">
    <div class="col-6 col-md-2">
        <div class="summary-card border border-primary bg-white shadow-sm">
            <div class="text-muted">Total Items</div>
            <div class="val text-primary" id="cardTotal">0</div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="summary-card border border-success bg-white shadow-sm">
            <div class="text-muted">Total Produce Qty</div>
            <div class="val text-success" id="cardProduced">0</div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="summary-card border border-danger bg-white shadow-sm">
            <div class="text-muted">Total Reject Qty</div>
            <div class="val text-danger" id="cardReject">0</div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="summary-card border border-warning bg-white shadow-sm">
            <div class="text-muted">Pending Production</div>
            <div class="val text-warning" id="cardPending">0</div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="summary-card border border-info bg-white shadow-sm">
            <div class="text-muted">Inventory Cost</div>
            <div class="val text-info" id="cardCost">₹0</div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="summary-card border border-secondary bg-white shadow-sm">
            <div class="text-muted">Basic Cost</div>
            <div class="val text-secondary" id="cardBasic">₹0</div>
        </div>
    </div>
</div>

<!-- ══════════ TABLE ══════════ -->
<div class="table-responsive border rounded shadow-sm"
     style="max-height:500px; overflow-y:auto;">
    <table class="table table-bordered mb-0" id="prodTable">
        <thead>
            <!-- GROUP HEADER ROW -->
            <tr>
                <th colspan="3">Identity</th>
                <th colspan="2">Product Info</th>
                <th colspan="1">Rate</th>
                <th colspan="5">Quantity Tracking</th>
                <th colspan="2">Stock Limits</th>
                <th colspan="2">FG Status</th>
                <th colspan="2">Costing</th>
            </tr>
            <!-- COLUMN HEADER ROW -->
            <tr>
    <th>Sr</th>
    <th>Dept</th>
    <th>Item Code</th>
    <th>Description</th>
    <th>Shot Wt/ps (g)</th>
    <th>Sale Rate (₹)</th>
    <th>Open FG</th>
    <th>Schedule</th>
    <th>Plan Qty</th>
    <th>Produce</th>
    <th>Reject</th>
    <th>Dispatch</th>
    <th>MIN</th>
    <th>MAX</th>
    <th>FG Qty</th>
    <th>To Produce</th>
    <th>Pending Prod.</th>
    <th>Inv. Cost (₹)</th>
    <th>Basic Cost (₹)</th>
</tr>
        </thead>
        <tbody id="tableBody">
            <!-- JS renders rows here -->
        </tbody>
        <!-- TOTALS FOOTER -->
        <tfoot>
            <tr style="font-size:0.68rem; font-weight:700;
                       background:#1a1a2e; color:#fff;">
                <td colspan="6" class="text-end pe-2">Totals :</td>
                <td class="num" id="fOpenFG"></td>
                <td class="num" id="fSchedule"></td>
                <td class="num" id="fPlan"></td>
                <td class="num" id="fProduce"></td>
                <td class="num" id="fReject"></td>
                <td class="num" id="fDispatch"></td>
                <td></td>
                <td></td>
                <td class="num" id="fFGQty"></td>
                <td class="num" id="fToProduce"></td>
                <td class="num" id="fPending"></td>
                <td class="num" id="fInvCost"></td>
                <td class="num" id="fBasicCost"></td>
            </tr>
        </tfoot>
    </table>
</div>

<!-- ══════════ PAGINATION ══════════ -->
<div class="pagination-bar">
    <span id="pageInfo" class="text-muted me-1"></span>
    <button class="btn btn-outline-secondary btn-sm"
            id="btnFirst" onclick="goToPage(1)">«</button>
    <button class="btn btn-outline-secondary btn-sm"
            id="btnPrev"  onclick="goToPage(currentPage-1)">‹</button>
    <span id="pageNumbers" class="d-flex gap-1"></span>
    <button class="btn btn-outline-secondary btn-sm"
            id="btnNext"  onclick="goToPage(currentPage+1)">›</button>
    <button class="btn btn-outline-secondary btn-sm"
            id="btnLast"  onclick="goToPage(totalPages)">»</button>
    <select id="rppSelect" class="form-select form-select-sm"
            style="width:75px" onchange="changeRPP()">
        <option value="5">5</option>
        <option value="10" selected>10</option>
        <option value="20">20</option>
        <option value="50">50</option>
    </select>
    <span class="text-muted">/ page</span>
</div>

@section Scripts {
<script>
// ══════════════════════════════════════════════════════
// SAMPLE DATA — IT Industry
// ══════════════════════════════════════════════════════
const rawData = [
    { dept:"Hardware",    code:"HW-001", desc:"Intel Core i7-13700K Processor",    shotWt:280,  saleRate:32000, openFG:15, schedule:50, plan:50, produce:48, reject:2, dispatch:40, min:10, max:100 },
