    { dept:"Hardware",    code:"HW-003", desc:"Samsung 1TB NVMe SSD",               shotWt:60,   saleRate:8200,  openFG:30, schedule:80, plan:80, produce:78, reject:2, dispatch:70, min:20, max:150 },
    { dept:"Hardware",    code:"HW-004", desc:"NVIDIA RTX 4060 GPU",                shotWt:890,  saleRate:38000, openFG:8,  schedule:25, plan:25, produce:24, reject:1, dispatch:20, min:5,  max:50  },
    { dept:"Hardware",    code:"HW-005", desc:"650W SMPS Power Supply",             shotWt:1200, saleRate:4800,  openFG:25, schedule:60, plan:60, produce:58, reject:2, dispatch:55, min:10, max:80  },
    { dept:"Hardware",    code:"HW-006", desc:"ATX Mid Tower Cabinet",              shotWt:3500, saleRate:3200,  openFG:12, schedule:40, plan:40, produce:39, reject:1, dispatch:35, min:8,  max:60  },
    { dept:"Hardware",    code:"HW-007", desc:"24\" FHD IPS Monitor",               shotWt:2800, saleRate:12500, openFG:20, schedule:45, plan:45, produce:44, reject:1, dispatch:40, min:5,  max:70  },
    { dept:"Hardware",    code:"HW-008", desc:"Mechanical Keyboard RGB",            shotWt:950,  saleRate:3800,  openFG:35, schedule:100,plan:100,produce:98, reject:2, dispatch:90, min:15, max:120 },
    { dept:"Hardware",    code:"HW-009", desc:"Optical Wireless Mouse",             shotWt:130,  saleRate:1200,  openFG:60, schedule:150,plan:150,produce:148,reject:2, dispatch:140,min:20, max:200 },
    { dept:"Hardware",    code:"HW-010", desc:"USB-C Hub 7-in-1",                  shotWt:180,  saleRate:2200,  openFG:40, schedule:120,plan:120,produce:118,reject:2, dispatch:110,min:20, max:180 },
    { dept:"Networking",  code:"NW-001", desc:"Cisco 24-Port Gigabit Switch",       shotWt:2200, saleRate:18000, openFG:10, schedule:30, plan:30, produce:29, reject:1, dispatch:25, min:5,  max:40  },
    { dept:"Networking",  code:"NW-002", desc:"TP-Link WiFi 6 Router AX3000",       shotWt:480,  saleRate:6500,  openFG:18, schedule:50, plan:50, produce:49, reject:1, dispatch:45, min:8,  max:80  },
    { dept:"Networking",  code:"NW-003", desc:"CAT6 UTP Cable 305m Box",            shotWt:8000, saleRate:3800,  openFG:5,  schedule:20, plan:20, produce:20, reject:0, dispatch:18, min:3,  max:30  },
    { dept:"Networking",  code:"NW-004", desc:"RJ45 Keystone Jack (Pack 24)",       shotWt:40,   saleRate:850,   openFG:100,schedule:300,plan:300,produce:298,reject:2, dispatch:280,min:50, max:500 },
    { dept:"Networking",  code:"NW-005", desc:"Fiber Patch Panel 24-Port",          shotWt:1800, saleRate:9500,  openFG:6,  schedule:18, plan:18, produce:17, reject:1, dispatch:15, min:3,  max:25  },
    { dept:"Software",    code:"SW-001", desc:"Windows 11 Pro OEM License",         shotWt:0,    saleRate:14500, openFG:50, schedule:100,plan:100,produce:100,reject:0, dispatch:90, min:20, max:200 },
    { dept:"Software",    code:"SW-002", desc:"MS Office 2021 Home & Business",     shotWt:0,    saleRate:22000, openFG:30, schedule:60, plan:60, produce:60, reject:0, dispatch:55, min:10, max:100 },
    { dept:"Software",    code:"SW-003", desc:"Antivirus 1Yr 3PC License",          shotWt:0,    saleRate:1800,  openFG:200,schedule:400,plan:400,produce:400,reject:0, dispatch:380,min:50, max:600 },
    { dept:"Software",    code:"SW-004", desc:"AutoCAD 2024 Annual Subscription",   shotWt:0,    saleRate:85000, openFG:5,  schedule:10, plan:10, produce:10, reject:0, dispatch:8,  min:2,  max:15  },
    { dept:"Software",    code:"SW-005", desc:"Adobe Creative Cloud 1Yr",           shotWt:0,    saleRate:54000, openFG:8,  schedule:15, plan:15, produce:15, reject:0, dispatch:12, min:2,  max:20  },
    { dept:"Assembly",    code:"AS-001", desc:"Desktop PC i5-13400 / 8GB / 512SSD", shotWt:5500, saleRate:42000, openFG:10, schedule:30, plan:30, produce:28, reject:2, dispatch:25, min:5,  max:50  },
    { dept:"Assembly",    code:"AS-002", desc:"Desktop PC i7-13700 / 16GB / 1TB",   shotWt:6200, saleRate:65000, openFG:6,  schedule:20, plan:20, produce:19, reject:1, dispatch:16, min:3,  max:30  },
    { dept:"Assembly",    code:"AS-003", desc:"Gaming PC RTX4060 / i7 / 32GB",      shotWt:7800, saleRate:115000,openFG:4,  schedule:12, plan:12, produce:11, reject:1, dispatch:9,  min:2,  max:20  },
    { dept:"Assembly",    code:"AS-004", desc:"Workstation Xeon / 64GB / 2TB",      shotWt:9500, saleRate:195000,openFG:2,  schedule:5,  plan:5,  produce:5,  reject:0, dispatch:4,  min:1,  max:10  },
    { dept:"Assembly",    code:"AS-005", desc:"Mini PC Intel N100 / 8GB / 256SSD",  shotWt:820,  saleRate:18500, openFG:15, schedule:40, plan:40, produce:39, reject:1, dispatch:35, min:8,  max:60  },
    { dept:"QA / Testing",code:"QA-001", desc:"Network Cable Tester",               shotWt:220,  saleRate:2800,  openFG:8,  schedule:20, plan:20, produce:20, reject:0, dispatch:18, min:3,  max:30  },
    { dept:"QA / Testing",code:"QA-002", desc:"Digital Multimeter",                 shotWt:310,  saleRate:1500,  openFG:12, schedule:25, plan:25, produce:24, reject:1, dispatch:22, min:5,  max:40  },
    { dept:"QA / Testing",code:"QA-003", desc:"POST Diagnostic Card PCI",           shotWt:85,   saleRate:950,   openFG:20, schedule:50, plan:50, produce:49, reject:1, dispatch:45, min:10, max:80  },
    { dept:"QA / Testing",code:"QA-004", desc:"Thermal Paste Syringe 5g",           shotWt:8,    saleRate:350,   openFG:150,schedule:400,plan:400,produce:398,reject:2, dispatch:380,min:50, max:600 },
    { dept:"QA / Testing",code:"QA-005", desc:"ESD Anti-Static Wrist Strap",        shotWt:35,   saleRate:280,   openFG:80, schedule:200,plan:200,produce:200,reject:0, dispatch:190,min:30, max:300 },
];

// ── Derive computed columns ──
const data = rawData.map((r, i) => {
    const fgQty      = r.openFG + r.produce - r.dispatch - r.reject;
    const toProduce  = Math.max(0, r.schedule - r.produce);
    const pending    = Math.max(0, r.plan - r.produce);
    // Basic cost = Shot Wt (g) × 0.08/g (approx resin/component cost)
    const basicCost  = r.shotWt > 0
        ? Math.round(r.shotWt * 0.08 * fgQty)
        : Math.round(r.saleRate * 0.45 * fgQty); // software: 45% of sale
    const invCost    = Math.round(r.saleRate * fgQty);

    return { ...r, srNo: i+1, fgQty, toProduce, pending, basicCost, invCost };
});

// ════════════════════════════════════════════
// PAGINATION STATE
// ════════════════════════════════════════════
let currentPage  = 1;
let rowsPerPage  = 10;
let totalPages   = 1;
let filteredData = [...data];

// ════════════════════════════════════════════
// RENDER
// ════════════════════════════════════════════
function fmt(n)  { return n.toLocaleString('en-IN'); }
function fmtC(n) { return '₹' + n.toLocaleString('en-IN'); }

function statusBadge(val, min, max) {
    if (val <= 0)    return `<span class="badge badge-low">Empty</span>`;
    if (val < min)   return `<span class="badge badge-warn">Low</span>`;
    if (val > max)   return `<span class="badge badge-high">Excess</span>`;
    return `<span class="badge badge-ok">OK</span>`;
}

function renderTable() {
    const tbody  = document.getElementById('tableBody');
    const start  = (currentPage - 1) * rowsPerPage;
    const end    = Math.min(start + rowsPerPage, filteredData.length);
    const slice  = filteredData.slice(start, end);

    tbody.innerHTML = slice.map(r => `
        <tr>
            <td class="text-center col-identity">${r.srNo}</td>
            <td class="col-identity">
                <span class="badge rounded-pill bg-dark"
                      style="font-size:0.60rem">${r.dept}</span>
            </td>
            <td class="col-identity fw-bold text-primary">${r.code}</td>
            <td>${r.desc}</td>
            <td class="num col-weight">${r.shotWt > 0 ? fmt(r.shotWt) : '—'}</td>
            <td class="num col-weight">${fmtC(r.saleRate)}</td>
            <td class="num col-qty">${fmt(r.openFG)}</td>
            <td class="num col-qty">${fmt(r.schedule)}</td>
            <td class="num col-qty">${fmt(r.plan)}</td>
            <td class="num col-qty">${fmt(r.produce)}</td>
            <td class="num col-qty text-danger fw-bold">${fmt(r.reject)}</td>
            <td class="num col-qty">${fmt(r.dispatch)}</td>
            <td class="num col-alert text-danger">${fmt(r.min)}</td>
            <td class="num col-alert text-success">${fmt(r.max)}</td>
            <td class="num col-fg fw-bold">
                ${fmt(r.fgQty)}
                <br>${statusBadge(r.fgQty, r.min, r.max)}
            </td>
            <td class="num col-fg text-warning fw-bold">${fmt(r.toProduce)}</td>
            <td class="num col-fg ${r.pending > 0 ? 'text-danger fw-bold' : 'text-success'}">
                ${fmt(r.pending)}
            </td>
            <td class="num col-cost">${fmtC(r.invCost)}</td>
            <td class="num col-cost">${fmtC(r.basicCost)}</td>
        </tr>`).join('');

    updateFooter();
    updatePagination(start, end);
    updateSummaryCards();
}

function updateFooter() {
    const sum = (key) => filteredData.reduce((a, r) => a + r[key], 0);
    document.getElementById('fOpenFG').textContent    = fmt(sum('openFG'));
    document.getElementById('fSchedule').textContent  = fmt(sum('schedule'));
    document.getElementById('fPlan').textContent      = fmt(sum('plan'));
    document.getElementById('fProduce').textContent   = fmt(sum('produce'));
    document.getElementById('fReject').textContent    = fmt(sum('reject'));
    document.getElementById('fDispatch').textContent  = fmt(sum('dispatch'));
    document.getElementById('fFGQty').textContent     = fmt(sum('fgQty'));
    document.getElementById('fToProduce').textContent = fmt(sum('toProduce'));
    document.getElementById('fPending').textContent   = fmt(sum('pending'));
    document.getElementById('fInvCost').textContent   = fmtC(sum('invCost'));
    document.getElementById('fBasicCost').textContent = fmtC(sum('basicCost'));
}

function updateSummaryCards() {
    const sum = (key) => filteredData.reduce((a, r) => a + r[key], 0);
    document.getElementById('cardTotal').textContent   = filteredData.length;
    document.getElementById('cardProduced').textContent= fmt(sum('produce'));
    document.getElementById('cardReject').textContent  = fmt(sum('reject'));
    document.getElementById('cardPending').textContent = fmt(sum('pending'));
    document.getElementById('cardCost').textContent    = fmtC(sum('invCost'));
    document.getElementById('cardBasic').textContent   = fmtC(sum('basicCost'));
}

function updatePagination(start, end) {
    totalPages = Math.max(1, Math.ceil(filteredData.length / rowsPerPage));
    if (currentPage > totalPages) currentPage = totalPages;

    document.getElementById('pageInfo').textContent =
        filteredData.length === 0
            ? 'No records'
            : `${start + 1}–${end} of ${filteredData.length}`;

    document.getElementById('btnFirst').disabled = currentPage === 1;
    document.getElementById('btnPrev').disabled  = currentPage === 1;
    document.getElementById('btnNext').disabled  = currentPage === totalPages;
    document.getElementById('btnLast').disabled  = currentPage === totalPages;

    const container  = document.getElementById('pageNumbers');
    container.innerHTML = '';
    const maxVis = 5;
    let sp = Math.max(1, currentPage - Math.floor(maxVis / 2));
    let ep = Math.min(totalPages, sp + maxVis - 1);
    if (ep - sp < maxVis - 1) sp = Math.max(1, ep - maxVis + 1);

    for (let p = sp; p <= ep; p++) {
        const btn = document.createElement('button');
        btn.textContent = p;
        btn.className   = 'btn btn-outline-secondary btn-sm'
                        + (p === currentPage ? ' active-page' : '');
        btn.onclick     = () => goToPage(p);
        container.appendChild(btn);
    }
}

function goToPage(p) {
    if (p < 1 || p > totalPages) return;
    currentPage = p;
    renderTable();
}

function changeRPP() {
    rowsPerPage = parseInt(document.getElementById('rppSelect').value);
    currentPage = 1;
    renderTable();
}

// ════════════════════════════════════════════
// FILTER
// ════════════════════════════════════════════
function filterTable() {
    const q    = document.getElementById('searchInput').value.toLowerCase().trim();
    const dept = document.getElementById('deptFilter').value;

    filteredData = data.filter(r => {
        const matchDept = !dept || r.dept === dept;
        const matchQ    = !q
            || r.code.toLowerCase().includes(q)
            || r.desc.toLowerCase().includes(q)
            || r.dept.toLowerCase().includes(q);
        return matchDept && matchQ;
    });

    currentPage = 1;
    renderTable();
}

// ════════════════════════════════════════════
// CSV EXPORT
// ════════════════════════════════════════════
function exportCSV() {
    const headers = [
        'Sr','Dept','Item Code','Description','Shot Wt/ps(g)',
        'Sale Rate','Open FG','Schedule','Plan','Produce',
        'Reject','Dispatch','MIN','MAX','FG Qty',
        'To Produce','Pending','Inv Cost','Basic Cost'
    ];
    const rows = filteredData.map(r => [
        r.srNo, r.dept, r.code, `"${r.desc}"`, r.shotWt,
        r.saleRate, r.openFG, r.schedule, r.plan, r.produce,
        r.reject, r.dispatch, r.min, r.max, r.fgQty,
        r.toProduce, r.pending, r.invCost, r.basicCost
    ]);
    const csv  = [headers, ...rows].map(r => r.join(',')).join('\n');
    const blob = new Blob([csv], { type: 'text/csv' });
    const a    = document.createElement('a');
    a.href     = URL.createObjectURL(blob);
    a.download = 'ProductionInventory.csv';
    a.click();
}

